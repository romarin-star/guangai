{
  "name": "irrigation-controller",
  "version": "1.0.0",
  "description": "智灌管家",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"node backend.js\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "railway:start": "node backend.js",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "axios": "^1.6.0",
    "cors": "^2.8.6",
    "element-plus": "^2.4.0",
    "express": "^4.22.1",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.irrigation.controller",
    "productName": "智灌管家",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend.js",
      "node_modules/**/*"
    ],
    "asar": false,
    "asarUnpack": [],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
